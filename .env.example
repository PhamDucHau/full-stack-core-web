# ============== Docker Compose ==============
# Copy file này thành .env ở thư mục gốc (full-stack-core-web) khi chạy docker-compose.

# Cổng các service (mặc định: backend 3001, frontend 3000, mongo 27017)
BACKEND_PORT=3001
FRONTEND_PORT=3000
MONGO_PORT=27017

# MongoDB - dùng khi chạy với container mongo trong docker-compose
MONGODB_URI=mongodb://admin:admin123@mongo:27017/core-web-cms?authSource=admin

# MongoDB credentials (cho container mongo)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin123

# Backend
JWT_SECRET=super_secret_key_123
FRONTEND_URL=http://localhost:3000

# Frontend - URL API mà trình duyệt gọi (phải trỏ tới backend)
NEXT_PUBLIC_API_URL=http://localhost:3001
